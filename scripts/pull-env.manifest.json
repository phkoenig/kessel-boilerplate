      "opReferenceEnvName": "OP_REF_NEXT_PUBLIC_SUPABASE_URL",
      "required": true,
      "vercel": true,
      "description": "Supabase URL der Dev-DB (MegaBrain Default, Projekt `jpmhwyjiuodsvjowddsm`)"
    },
    {
      "envName": "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
      "source": "1password",
      "opReference": "op://${OP_VAULT}/App Runtime/NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
      "opReferenceEnvName": "OP_REF_NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
